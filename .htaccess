<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^www\.gubotspraybooth\.com$ [NC]
  RewriteRule ^ https://www.gubotspraybooth.com%{REQUEST_URI} [R=301,L]

  RewriteRule ^home/?$ / [R=301,L]
  RewriteRule ^index\.html$ / [R=301,L]
  RewriteRule ^about-us/?$ /about.html [R=301,L]
  RewriteRule ^product-list/?$ /product.html [R=301,L]
  RewriteRule ^configurator/?$ /configurator.html [R=301,L]
  RewriteRule ^paint-booth-configurator/?$ /configurator.html [R=301,L]
  RewriteRule ^case-list/?$ /cases.html [R=301,L]
  RewriteRule ^contact-us/?$ /contact.html [R=301,L]
  RewriteRule ^news-list/?$ /news.html [R=301,L]
  RewriteRule ^thank-you/?$ /thank-you.html [R=301,L]
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 5 minutes"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|svg|css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.php$">
    Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
  </FilesMatch>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>
